{
  "name": "casing.run",
  "displayName": "Casing.run",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git@github.com:jaidlab/casing.run.git"
  },
  "exports": {
    ".": {
      "default": "./src/main.ts"
    }
  },
  "imports": {
    "#src/*": "./src/*",
    "#root/*": "./*"
  },
  "scripts": {
    "build": "bun run vite build --mode development",
    "build:production": "bun run vite build --mode production",
    "lint": "tsc --noEmit --noUnusedLocals --pretty false && knip-bun --exclude dependencies --reporter json",
    "serve": "bun run build:production && bun run vite --port 443 --host 0.0.0.0 preview --outDir dist/production",
    "test-live": "bun run build:production && target=dist/production bun test test/live.test.ts",
    "vite": "bun node_modules/vite/dist/node/cli.js --configLoader runner"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "vite-plugin-media-mixins": "^0.4.0",
    "vite-plugin-title": "^0.5.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@types/postcss-normalize": "^9.0.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.5.0",
    "babel-plugin-react-compiler": "1.0.0",
    "browserslist": "4.28.2",
    "bun-types": "1.3.14",
    "caniuse-lite": "1.0.30001792",
    "count-in-png": "0.1.0",
    "cssnano-preset-advanced": "8.0.1",
    "es-toolkit": "1.46.1",
    "eslint": "10.4.0",
    "eslint-config-jaid": "26.0.0",
    "fs-extra": "11.3.5",
    "knip": "6.14.0",
    "optis": "0.1.0",
    "postcss-normalize": "13.0.1",
    "puppeteer-core": "25.0.2",
    "sass-embedded": "1.99.0",
    "tsconfig-jaid-react": "15.2.0",
    "type-fest": "5.6.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vite-plugin-pwa": "1.3.0"
  }
}